NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# If true, auth middleware is bypassed in local dev
NEXT_PUBLIC_AUTH_BYPASS=true

# Connector toggles
ENABLE_REDDIT_CONNECTOR=true
ENABLE_YOUTUBE_CONNECTOR=true
ENABLE_TIKTOK_CONNECTOR=true
ENABLE_FACEBOOK_CONNECTOR=true
ENABLE_OPENROUTER_CONNECTOR=true
ENABLE_NEWS_CONNECTOR=true

# Provider API keys for production connector implementations
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SignalSentiment/1.0
YOUTUBE_API_KEY=
TIKTOK_ACCESS_TOKEN=

# Facebook Graph API credentials
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=

# Optional: override Graph API base version
FACEBOOK_GRAPH_BASE_URL=https://graph.facebook.com/v21.0

# OpenRouter sentiment source
OPENROUTER_API_KEY=
OPENROUTER_MAX_MODELS=3
OPENROUTER_REQUEST_TIMEOUT_MS=60000
OPENROUTER_MAX_TOKENS=500
OPENROUTER_RETRIES=1
OPENROUTER_CONCURRENCY=2
OPENROUTER_MODEL_ALLOWLIST=
OPENROUTER_MODEL_PREFERENCE=

# Refresh job behavior
REFRESH_TIMEOUT_MS=240000

# UI display timezone
NEXT_PUBLIC_DISPLAY_TIMEZONE=America/Detroit

# Reddit relevance tuning
REDDIT_RELEVANCE_THRESHOLD=0.68

# RSS news source controls
NEWS_ENABLE_NASDAQ=true
NEWS_ENABLE_SEEKING_ALPHA=true
NEWS_ENABLE_INVESTING=true
NEWS_ENABLE_MARKETWATCH=false

NEWS_FETCH_TIMEOUT_MS=12000
NEWS_RETRY_COUNT=1
NEWS_CACHE_TTL_SEC=300
NEWS_CIRCUIT_FAILURE_THRESHOLD=3
NEWS_CIRCUIT_OPEN_MS=120000

NEWS_SOURCE_ALLOWLIST=
NEWS_SOURCE_BLOCKLIST=
NEWS_RELEVANCE_MIN=0.35

NEWS_SOURCE_PRIORITY_NASDAQ=5
NEWS_SOURCE_PRIORITY_SEEKING_ALPHA=4
NEWS_SOURCE_PRIORITY_INVESTING=3
NEWS_SOURCE_PRIORITY_MARKETWATCH=2

NEWS_WEIGHT_RECENCY=0.25
NEWS_WEIGHT_RELEVANCE=0.4
NEWS_WEIGHT_SOURCE_PRIORITY=0.35

NEWS_USER_AGENT=SentiNewsBot/1.0 (+https://senti.app)
NEWS_NASDAQ_FEED_URL_TEMPLATE=https://www.nasdaq.com/feed/rssoutbound?symbol={symbol}
NEWS_NASDAQ_FALLBACK_FEED_URL=https://www.nasdaq.com/feed/rssoutbound?category=Business
NEWS_SEEKING_ALPHA_SYMBOL_FEED_URL_TEMPLATE=https://seekingalpha.com/api/sa/combined/{symbol}.xml
NEWS_SEEKING_ALPHA_FALLBACK_FEED_URL=https://seekingalpha.com/feed.xml
NEWS_INVESTING_FEED_URLS=https://www.investing.com/rss/news_25.rss,https://www.investing.com/rss/news.rss
# Optional and disabled by default (check licensing/terms before enabling):
NEWS_MARKETWATCH_FEED_URL=https://feeds.marketwatch.com/marketwatch/topstories/
