NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# If true, auth middleware is bypassed in local dev
NEXT_PUBLIC_AUTH_BYPASS=true

# Connector toggles
ENABLE_REDDIT_CONNECTOR=true
ENABLE_YOUTUBE_CONNECTOR=true
ENABLE_TIKTOK_CONNECTOR=true
ENABLE_FACEBOOK_CONNECTOR=true
ENABLE_OPENROUTER_CONNECTOR=true

# Provider API keys for production connector implementations
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SignalSentiment/1.0
YOUTUBE_API_KEY=
TIKTOK_ACCESS_TOKEN=

# Facebook Graph API credentials
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=

# Optional: override Graph API base version
FACEBOOK_GRAPH_BASE_URL=https://graph.facebook.com/v21.0

# OpenRouter sentiment source
OPENROUTER_API_KEY=
OPENROUTER_MAX_MODELS=8
